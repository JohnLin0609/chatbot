# Keep the backend build context small and secrets out of the image.
.git/
.venv/
venv/
__pycache__/
**/__pycache__/
*.pyc
.pytest_cache/
.claude/

# Not needed by the backend image (frontend has its own build).
frontend/
tests/
docs/
*.md

# Secrets come in at runtime via env_file, never baked into the image.
.env
