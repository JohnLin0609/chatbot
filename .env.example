# ----------------------------------------------------------------- LLM
# Which provider to use: anthropic | openai | gemini | ollama
PROVIDER=openai

# Model name. Leave empty to use the provider's default:
#   anthropic -> claude-sonnet-4-6
#   openai    -> gpt-4o-mini
#   gemini    -> gemini-2.0-flash
#   ollama    -> llama3.2
MODEL=

# API keys — only the one for the selected provider is needed.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Ollama runs locally, no key needed — just the host.
OLLAMA_HOST=http://localhost:11434

# Shared generation settings.
MAX_TOKENS=1024
# SYSTEM_PROMPT=You are a friendly, concise assistant.

# --------------------------------------------------------------- Redis
# Dedicated host ports from docker-compose (6380/5433) so this project's
# Redis/Postgres don't collide with any 6379/5432 already on the machine.
REDIS_URL=redis://localhost:6380/0
REDIS_KEY_PREFIX=chat
INBOUND_STREAM=chat:inbound
OUTBOUND_STREAM=chat:outbound
CORE_CONSUMER_GROUP=core-workers
HTTP_CONSUMER_GROUP=http-gateway
CLI_CONSUMER_GROUP=cli-gateway
DISCORD_CONSUMER_GROUP=discord-gateway
# Ephemeral pub/sub channel for live progress (tool/think status -> adapters).
PROGRESS_CHANNEL=chat:progress

# ------------------------------------------------------------ Postgres
POSTGRES_DSN=postgresql+asyncpg://chat:chat@localhost:5434/chat

# ------------------------------------------------------- Tokenisation
TIKTOKEN_ENCODING=o200k_base

# ------------------------------------------------------- Memory/context
HOT_TTL_SECONDS=604800
# Tier-1 current-context window (whole turns kept under this token budget)
CONTEXT_WINDOW_TOKENS=3000

# --------------------------------------------------- Tier-2 channel summary
CHANNEL_SUMMARY_TOKEN_CAP=150

# ------------------------------------------------ Tier-3 per-user fact memory
FACT_EXTRACTION_TOKENS=6000
FACT_EXTRACTION_ASYNC=false
PERSONAL_MEMORY_TOKEN_CAP=800
ROLLING_SUMMARY_TOKEN_CAP=400
FACT_CONFIDENCE_WEIGHT=1.0
FACT_RECENCY_WEIGHT=1.0
FACT_RECENCY_HALFLIFE_DAYS=30

# ------------------------------------------------------------- Gateway
REPLY_TIMEOUT_SECONDS=30

# ------------------------------------------------- Tier-4 RAG / vector store
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=knowledge
# Embedding model is fixed for the whole collection (independent of PROVIDER).
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_BATCH_SIZE=64
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.0
INGEST_CHUNK_TOKENS=512
INGEST_CHUNK_OVERLAP=64
# Per-type chunking: default strategy + spaCy sentence-grouping (prose).
DEFAULT_CHUNK_STRATEGY=prose
SPACY_MODEL=xx_sent_ud_sm
CHUNK_SENTENCE_OVERLAP=1
# Hybrid (dense + BM25 sparse) retrieval.
RAG_SPARSE_ENABLED=true
RAG_SPARSE_VECTOR_NAME=text-sparse
RAG_PREFETCH_LIMIT=50
RAG_FUSION=rrf
# Adaptive-RAG routing (front LLM classifier: simple/medium/complex).
ADAPTIVE_CLASSIFIER_ENABLED=true
ADAPTIVE_CLASSIFIER_MODEL=
RAG_MEDIUM_TOP_K=3
RAG_COMPLEX_CANDIDATES=20
RAG_COMPLEX_TOP_K=3
# Rerank (complex tier only) — local Qwen3-Reranker.
RAG_RERANKER_ENABLED=true
RAG_RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B
RAG_RERANKER_DEVICE=auto

# ------------------------------------------------------------- Tools
ENABLE_TOOLS=true
TOOL_MAX_ITERATIONS=4

# --------------------------------------------------- Web search (Brave API)
# The web_search tool is registered ONLY when BRAVE_API_KEY is set.
BRAVE_API_KEY=
BRAVE_SEARCH_URL=https://api.search.brave.com/res/v1/web/search
BRAVE_SEARCH_COUNT=5
# Optional region/language defaults (blank = Brave's default)
BRAVE_SEARCH_COUNTRY=
BRAVE_SEARCH_LANG=
BRAVE_SEARCH_TIMEOUT=8.0

# ------------------------------------------------------------- Discord
# Required to run interfaces.discord_app. Enable the "Message Content Intent"
# (privileged) for this bot in the Discord Developer Portal.
DISCORD_BOT_TOKEN=
# Optional CSV of guild IDs the bot will answer in (blank = all guilds).
DISCORD_ALLOWED_GUILDS=
