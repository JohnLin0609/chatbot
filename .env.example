# ----------------------------------------------------------- Environment
# dev (default) | production. Production enforces a safe configuration at
# startup: JWT_SECRET required, explicit CORS_ALLOW_ORIGINS (no "*"), and
# registration closed unless AUTH_OPEN_REGISTRATION is set explicitly.
APP_ENV=dev

# ----------------------------------------------------------------- LLM
# Which provider to use: anthropic | openai | gemini | ollama
PROVIDER=openai

# Model name. Leave empty to use the provider's default:
#   anthropic -> claude-sonnet-4-6
#   openai    -> gpt-4o-mini
#   gemini    -> gemini-2.0-flash
#   ollama    -> llama3.2
MODEL=

# API keys — only the one for the selected provider is needed.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Ollama runs locally, no key needed — just the host.
OLLAMA_HOST=http://localhost:11434

# Shared generation settings.
MAX_TOKENS=1024
# SYSTEM_PROMPT=You are a friendly, concise assistant.

# Upstream LLM resilience: hard deadline per call + bounded retries with
# exponential backoff (applies to every provider, incl. judge/golden runs).
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_SECONDS=1.0

# --------------------------------------------------------------- Redis
# Dedicated host ports from docker-compose (6380/5434) so this project's
# Redis/Postgres don't collide with any 6379/5432 already on the machine.
#
# NOTE: when running the full stack in Docker (`docker compose --profile app up`),
# REDIS_URL / POSTGRES_DSN / QDRANT_URL are overridden in compose to reach the
# stores by service name (redis:6379 / postgres:5432 / qdrant:6333), so the values
# here are only used for host-run. In Docker you just need the provider key(s) +
# JWT_SECRET set in this file.
REDIS_URL=redis://localhost:6380/0
REDIS_KEY_PREFIX=chat
INBOUND_STREAM=chat:inbound
OUTBOUND_STREAM=chat:outbound
CORE_CONSUMER_GROUP=core-workers
HTTP_CONSUMER_GROUP=http-gateway
CLI_CONSUMER_GROUP=cli-gateway
DISCORD_CONSUMER_GROUP=discord-gateway
# Ephemeral pub/sub channel for live progress (tool/think status -> adapters).
PROGRESS_CHANNEL=chat:progress

# ------------------------------------------------------------ Postgres
POSTGRES_DSN=postgresql+asyncpg://chat:chat@localhost:5434/chat

# ------------------------------------------------------- Tokenisation
TIKTOKEN_ENCODING=o200k_base

# ------------------------------------------------------- Memory/context
# Session conversation cache (recent turns + channel summary); 10 min idle =
# user left -> the worker sweeper finalises the session into durable memory.
HOT_TTL_SECONDS=600
# Tier-3 per-user memory mirror — decoupled so the short session TTL doesn't
# thrash per-user memory caching (Postgres stays authoritative).
USER_MEMORY_TTL_SECONDS=604800
# Tier-1 current-context window (whole turns kept under this token budget)
CONTEXT_WINDOW_TOKENS=3000

# ----------------------------------------- Session finalization (worker sweeper)
SESSION_FINALIZE_ENABLED=true
SESSION_FINALIZE_IDLE_SECONDS=600
SESSION_SWEEP_INTERVAL_SECONDS=60
SESSION_SWEEP_BATCH=50

# ----------------------------------------- Eval logging (analysis / future judge)
# Persist each turn's full context (query, retrieved candidates + scores/ranks,
# injected context, reply, token/latency) for retrieval + generation metrics.
# Best-effort + async; never blocks the reply.
EVAL_LOGGING_ENABLED=true
# Set false to keep metadata + token counts but null the message/reply/chunk
# bodies (privacy / size).
EVAL_LOG_MESSAGE_BODIES=true
EVAL_CHUNK_TEXT_MAX=2000

# ----------------------------------------- LLM-as-judge (Phase B; batch / admin-run)
JUDGE_ENABLED=true
# Judge provider/model — leave blank to reuse the main PROVIDER/MODEL.
# JUDGE_PROVIDER=openai
# JUDGE_MODEL=gpt-5.4-mini
JUDGE_BATCH_SIZE=20

# ----------------------------------------- Golden eval set (Phase C; admin-run)
# k values for @k retrieval metrics + how many candidates to rank per query.
GOLDEN_EVAL_K_VALUES=[1,3,5]
GOLDEN_EVAL_CANDIDATES=20

# --------------------------------------------------- Tier-2 channel summary
CHANNEL_SUMMARY_TOKEN_CAP=150

# ------------------------------------------------ Tier-3 per-user fact memory
FACT_EXTRACTION_TOKENS=6000
FACT_EXTRACTION_ASYNC=false
PERSONAL_MEMORY_TOKEN_CAP=800
ROLLING_SUMMARY_TOKEN_CAP=400
FACT_CONFIDENCE_WEIGHT=1.0
FACT_RECENCY_WEIGHT=1.0
FACT_RECENCY_HALFLIFE_DAYS=30

# ------------------------------------------------------------- Gateway
REPLY_TIMEOUT_SECONDS=30

# ------------------------------------------------------------- Auth (API)
# JWT signing secret — set a long random value in prod (>=32 bytes). If empty,
# an ephemeral dev secret is used and tokens won't survive a restart.
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440
# Open self-registration; the first account created becomes admin.
# Defaults to false when APP_ENV=production (set explicitly to keep it open).
AUTH_OPEN_REGISTRATION=true

# CSV of allowed CORS origins; "*" = any (dev only — production requires an
# explicit list, e.g. https://chat.example.com).
CORS_ALLOW_ORIGINS=*

# Redis fixed-window rate limits, per minute. Auth keys on client IP;
# chat keys on the authenticated user id.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_CHAT_PER_MINUTE=20

# ------------------------------------------------- Tier-4 RAG / vector store
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=knowledge
# Embedding model is fixed for the whole collection (independent of PROVIDER).
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_BATCH_SIZE=64
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.0
INGEST_CHUNK_TOKENS=512
INGEST_CHUNK_OVERLAP=64
# Per-type chunking: default strategy + spaCy sentence-grouping (prose).
DEFAULT_CHUNK_STRATEGY=prose
SPACY_MODEL=xx_sent_ud_sm
CHUNK_SENTENCE_OVERLAP=1
# Hybrid (dense + BM25 sparse) retrieval.
RAG_SPARSE_ENABLED=true
RAG_SPARSE_VECTOR_NAME=text-sparse
RAG_PREFETCH_LIMIT=50
RAG_FUSION=rrf
# Adaptive-RAG routing (front LLM classifier: simple/medium/complex).
ADAPTIVE_CLASSIFIER_ENABLED=true
ADAPTIVE_CLASSIFIER_MODEL=
RAG_MEDIUM_TOP_K=3
RAG_COMPLEX_CANDIDATES=20
RAG_COMPLEX_TOP_K=3
# Rerank (complex tier only) — local Qwen3-Reranker.
RAG_RERANKER_ENABLED=true
RAG_RERANKER_MODEL=Qwen/Qwen3-Reranker-0.6B
RAG_RERANKER_DEVICE=auto

# ------------------------------------------------------------- Tools
ENABLE_TOOLS=true
TOOL_MAX_ITERATIONS=4

# --------------------------------------------------- Web search (Brave API)
# The web_search tool is registered ONLY when BRAVE_API_KEY is set.
BRAVE_API_KEY=
BRAVE_SEARCH_URL=https://api.search.brave.com/res/v1/web/search
BRAVE_SEARCH_COUNT=5
# Optional region/language defaults (blank = Brave's default)
BRAVE_SEARCH_COUNTRY=
BRAVE_SEARCH_LANG=
BRAVE_SEARCH_TIMEOUT=8.0

# ------------------------------------------------------------- Discord
# Required to run interfaces.discord_app. Enable the "Message Content Intent"
# (privileged) for this bot in the Discord Developer Portal.
DISCORD_BOT_TOKEN=
# Optional CSV of guild IDs the bot will answer in (blank = all guilds).
DISCORD_ALLOWED_GUILDS=
